{
  "//": "Ejemplo de configuración de hooks. Va en .claude/settings.json (compartido) o .claude/settings.local.json (personal, no versionado).",
  "//matcher": "El 'matcher' es una regex sobre el NOMBRE de la tool. '' o '*' = todas. 'Write|Edit|MultiEdit' = ediciones. 'Read|Grep' = lecturas.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Grep",
        "hooks": [
          { "type": "command", "command": "node ./hooks/read_hook.js" }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "node ./hooks/query_hook.js", "timeout": 300 }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "node ./hooks/log_hook.js pre-log.json" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "node ./hooks/format_hook.js" },
          { "type": "command", "command": "node ./hooks/tsc.js" }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "node ./hooks/log_hook.js post-log.json" }
        ]
      }
    ]
  }
}
